Output assets/demo.gif

Set Theme "Catppuccin Mocha"
Set FontSize 15
Set Width 900
Set Height 450
Set Padding 20

# Scene 1: strip a painful AI commit message
Type `echo "Seamlessly implement a comprehensive authentication feature" | llmstrip`
Sleep 500ms
Enter
Sleep 1500ms

# Scene 2: strip classic AI prose
Type `echo "Certainly! Let me delve into this robust and comprehensive approach." | llmstrip`
Sleep 500ms
Enter
Sleep 1500ms

# Scene 3: report on AI code
Type `llmstrip --report --mode code assets/sample.py`
Sleep 500ms
Enter
Sleep 2000ms
